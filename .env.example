# NeuroHealth Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── LLM Configuration ──────────────────────────────────────
# HuggingFace model identifier (requires gated access approval)
MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct

# Your HuggingFace API token (get one at https://huggingface.co/settings/tokens)
# Must have access to the Llama 3.1 model
HUGGINGFACE_TOKEN=hf_YOUR_TOKEN_HERE

# Generation parameters
MAX_NEW_TOKENS=1024
TEMPERATURE=0.3

# ── Embedding Configuration ────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Vector Database ────────────────────────────────────────
VECTOR_DB_PATH=./data/vector_db

# ── Feature Flags ──────────────────────────────────────────
USE_LOCAL_LLM=true
