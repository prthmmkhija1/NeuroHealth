# Secrets
.env

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Data (too large for GitHub — .gitkeep files are tracked)
data/raw/*
data/processed/*
data/vector_db/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/vector_db/.gitkeep
# Sample data files are tracked for reviewer reference
!data/samples/

# Evaluation outputs — track result JSONs for submission, ignore large output dirs
# evaluation/ablation_results.json   ← tracked (committed after GPU run)
# evaluation/profiling_results.json  ← tracked (committed after GPU run)
# evaluation/benchmark_results.json  ← tracked (committed after GPU run)
# evaluation/safety_results.json     ← tracked (committed after GPU run)
# evaluation/equity_results.json     ← tracked (committed after GPU run)
# Track result JSONs from baseline and human eval (committed after GPU run)
!evaluation/human_eval_output/*.json
!evaluation/baseline_output/*.json

# Virtual environments
venv/
.venv/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Testing / logs
.pytest_cache/
*.log

# Jupyter
.ipynb_checkpoints/
