evaluation/profiling_results.json
evaluation/human_eval_output/
evaluation/baseline_output/

# Virtual environments
venv/
.venv/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Testing / logs
.pytest_cache/
*.log

# Jupyter
.ipynb_checkpoints/
